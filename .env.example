# JARVIS configuration — copy this file to `.env` and edit.
# All variables are optional; if omitted, defaults from core/config.py are used.

# --- Gemini ---
# If the API key is set here, config/api_keys.json is not needed
# JARVIS_GEMINI_API_KEY=AIza...
# JARVIS_LIVE_MODEL=models/gemini-3.1-flash-live
# JARVIS_VOICE_NAME=Charon

# --- Behavior ---
# JARVIS_SAFE_MODE=true              # require confirmation on destructive tools
# JARVIS_CTX_TOTAL_CAP=6000          # prompt context budget (characters)

# --- Wake word (only respond when addressed) ---
# JARVIS_WAKE_WORD_ENABLED=true      # set false to respond to everything
# JARVIS_WAKE_WORD=jarvis            # the word that must start your sentence

# --- Voice activity detection (don't cut off long sentences) ---
# JARVIS_VAD_SILENCE_MS=1400         # silence needed before a turn ends (raise = more patient)
# JARVIS_VAD_END_SENSITIVITY=low     # low = detects end later (long-sentence friendly)

# --- Audio ---
# JARVIS_INTERRUPT_RMS=0.18          # barge-in threshold (0-1). Raise = harder to interrupt
# JARVIS_AUDIO_QUEUE_MAX=1000

# --- Dashboard ---
# JARVIS_DASHBOARD_ENABLED=true
# JARVIS_DASHBOARD_PORT=8765

# --- Error tracking (optional) ---
# SENTRY_DSN=https://...@sentry.io/...
